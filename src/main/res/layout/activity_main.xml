<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/textEnunciado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enunciado_inicial"
        android:textSize="20sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/botonSonar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sonar_alarma"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/inputRespuesta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberSigned"
        android:hint="@string/tu_respuesta"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/botonResponder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/responder" />

    <TextView
        android:id="@+id/textResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginTop="16dp" />

</LinearLayout>
